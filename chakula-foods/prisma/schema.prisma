// Chakula Foods - Prisma Schema
// Uganda-based fast food, bakery, juice bar, fresh & dry market

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  VISA_MASTERCARD
  CASH
}

enum SubscriptionPlan {
  DAILY
  WEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum ProductCategory {
  FAST_FOOD
  BAKERY
  JUICE_BAR
  FRESH_MARKET
  DRY_MARKET
  ROASTS
  SPECIALS
  BREAKFAST
  PLATTERS
  DRINKS
  WINES_SPIRITS
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  SUBSCRIPTION
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String    @unique
  password      String
  role          Role      @default(CUSTOMER)
  avatar        String?
  address       String?
  latitude      Float?
  longitude     Float?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  subscriptions Subscription[]
  payments      Payment[]
  reviews       Review[]
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String          @id @default(cuid())
  name        String
  description String?
  image       String?
  type        ProductCategory @unique
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  products Product[]
}

model Product {
  id              String          @id @default(cuid())
  name            String
  description     String?
  price           Float
  image           String?
  category        ProductCategory
  categoryId      String?
  isAvailable     Boolean         @default(true)
  isFeatured      Boolean         @default(false)
  stock           Int?
  unit            String?
  preparationTime Int?
  allergens       String[]
  tags            String[]
  calories        Int?
  availableFrom   String?         // Opening time (HH:mm, e.g. "07:00")
  availableTo     String?         // Closing time (HH:mm, e.g. "22:00")
  availableDays   String[]        // Days of week ["mon","tue","wed","thu","fri","sat","sun"]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  categoryRef       Category?          @relation(fields: [categoryId], references: [id])
  orderItems        OrderItem[]
  reviews           Review[]
  subscriptionItems SubscriptionItem[]
  offers            Offer[]
  packageItems      PackageItem[]
  variants          ProductVariant[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  type            OrderType   @default(DINE_IN)
  status          OrderStatus @default(PENDING)
  tableNumber     String?
  deliveryAddress String?
  deliveryLat     Float?
  deliveryLng     Float?
  notes           String?
  subtotal        Float
  deliveryFee     Float       @default(0)
  discount        Float       @default(0)
  total           Float
  estimatedTime   Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  payment Payment?
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  notes      String?
  createdAt  DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime
  autoRenew       Boolean            @default(true)
  deliveryTime    String?
  deliveryDays    String[]
  deliveryAddress String?
  total           Float
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user     User               @relation(fields: [userId], references: [id])
  items    SubscriptionItem[]
  payments Payment[]
}

model SubscriptionItem {
  id             String @id @default(cuid())
  subscriptionId String
  productId      String
  quantity       Int
  unitPrice      Float

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  orderId        String?       @unique
  subscriptionId String?
  amount         Float
  currency       String        @default("UGX")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionId  String?
  providerRef    String?
  phoneNumber    String?
  metadata       Json?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Table {
  id        String   @id @default(cuid())
  number    String   @unique
  capacity  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
}

enum OfferType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_ONE_GET_ONE
}

model Offer {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        OfferType
  value       Float
  code        String?
  image       String?
  isActive    Boolean    @default(true)
  startDate   DateTime?
  endDate     DateTime?
  usageLimit  Int?
  usedCount   Int        @default(0)
  productId   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  product Product? @relation(fields: [productId], references: [id])

  @@index([code])
  @@index([isActive])
}

model Package {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PackageItem[]
}

model PackageItem {
  id        String  @id @default(cuid())
  packageId String
  productId String
  quantity  Int     @default(1)

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([packageId, productId])
}

model ProductVariant {
  id        String @id @default(cuid())
  productId String
  name      String // e.g., "Small", "Medium", "Large"
  price     Float? // Overrides base price if set
  stock     Int?
  isActive  Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@index([productId])
}
