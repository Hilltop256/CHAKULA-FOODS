# ================================================================
# CHAKULA FOODS - Environment Variables
# ================================================================
# 
# For Vercel deployment, set these in:
# https://vercel.com/[your-team]/[your-project]/settings/environment-variables
#
# For local development, copy this file to .env and fill in the values.
# ================================================================

# ----------------------------------------------------------------
# DATABASE (REQUIRED) - Supabase PostgreSQL
# ----------------------------------------------------------------
# IMPORTANT: For Vercel deployment, you need TWO connection strings:
#
# 1) DATABASE_URL - uses the POOLER (port 6543) for runtime queries
#    Get from: Supabase Dashboard → Settings → Database → Connection string → Transaction mode
#    Example: postgres://postgres.xxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# 2) DIRECT_URL - uses the DIRECT connection (port 5432) for migrations
#    Example: postgres://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
#
# Direct connections (port 5432) DO NOT WORK from Vercel serverless functions.
# Always use the pooler URL for DATABASE_URL.
# ----------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# ----------------------------------------------------------------
# ADMIN TEST MODE (for development/testing without login)
# ----------------------------------------------------------------
# Set to 'true' to let admin UI and APIs work without login
# Set to 'false' in production once you have real admin accounts
# ----------------------------------------------------------------
ADMIN_TEST_MODE=true

# ----------------------------------------------------------------
# APP URL (REQUIRED)
# ----------------------------------------------------------------
# Your deployed app URL. For Vercel, this is:
# https://[your-project-name].vercel.app
# ----------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------
# STORAGE (REQUIRED for image uploads) - Supabase Storage
# ----------------------------------------------------------------
# Create a storage bucket named 'media' in your Supabase dashboard
# and set the bucket to public. These are your Supabase credentials.
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=media

# ----------------------------------------------------------------
# PAYMENT & SMS (OPTIONAL - skip for testing)
# ----------------------------------------------------------------
# These are only needed when you want to accept real payments or send SMS.
# The app works fully without them using Cash on Delivery.
# ----------------------------------------------------------------
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=
MTN_API_USER=
MTN_API_KEY=
MTN_ENVIRONMENT=sandbox
AIRTEL_BASE_URL=https://openapiuat.airtel.africa
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
FLUTTERWAVE_SECRET_KEY=
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=CHAKULA
