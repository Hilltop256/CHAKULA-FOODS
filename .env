# =============================================================================
# CHAKULA FOODS - Environment Variables
# Next.js App Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required - app will not start without this)
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=your-postgresql-connection-string-here

# -----------------------------------------------------------------------------
# APP URL (Required for Flutterwave payment redirects)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# MTN Mobile Money (Uganda)
# Get credentials at: https://momodeveloper.mtn.com
# -----------------------------------------------------------------------------
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=your-mtn-subscription-key-here
MTN_API_USER=your-mtn-api-user-uuid-here
MTN_API_KEY=your-mtn-api-key-here
MTN_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# Airtel Money (Uganda)
# Get credentials at: https://developers.airtel.africa
# -----------------------------------------------------------------------------
AIRTEL_BASE_URL=https://openapiuat.airtel.africa
AIRTEL_CLIENT_ID=your-airtel-client-id-here
AIRTEL_CLIENT_SECRET=your-airtel-client-secret-here

# -----------------------------------------------------------------------------
# Flutterwave (Visa/Mastercard payments)
# Get credentials at: https://dashboard.flutterwave.com
# -----------------------------------------------------------------------------
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key-here

# -----------------------------------------------------------------------------
# Africa's Talking SMS (Uganda)
# Get credentials at: https://account.africastalking.com
# -----------------------------------------------------------------------------
AFRICASTALKING_API_KEY=your-africastalking-api-key-here
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=CHAKULA
